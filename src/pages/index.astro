<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chanryeol Lee</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..800;1,300..600&display=swap" rel="stylesheet">
<link rel="icon" href="/ll.svg" type="image/svg+xml">
<style is:global>
  :root[data-theme="dark"]{
    --bg:#18181b;
    --text:#ededed;
    --dim:#b6b6ba;
    --muted:#76767c;
    --line:#2a2a2f;
    --nav:#cfcfd4;
  }
  :root[data-theme="light"]{
    --bg:#fafafa;
    --text:#18181b;
    --dim:#3f3f46;
    --muted:#7a7a80;
    --line:#e4e4e7;
    --nav:#3f3f46;
  }

  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-text-size-adjust:100%}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:"Figtree",system-ui,sans-serif;
    font-size:15px;
    line-height:1.62;
    -webkit-font-smoothing:antialiased;
    transition:background .2s ease,color .2s ease;
  }

  .container{max-width:720px;margin:0 auto;padding:0 1.6rem}
  .intro a{color:var(--text);text-decoration:underline;text-underline-offset:2px}
  /* ---- top nav ---- */
  nav{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:1.4rem 0;
  }
  .logo{
  width:34px;height:34px;
  display:flex;align-items:center;justify-content:center;
  color:var(--text);font-weight:700;font-size:0.85rem;
  text-decoration:none;
}
.logo img,.logo svg{width:100%;height:100%;object-fit:contain}
  .nav-links{display:flex;align-items:center;gap:1.4rem}
  .nav-links a{
    color:var(--nav);text-decoration:none;font-size:0.95rem;
    transition:color .15s ease;
  }
  .nav-links a:hover,.nav-links a:focus-visible{color:var(--text)}
  .toggle{
    background:none;border:none;cursor:pointer;color:var(--nav);
    display:flex;align-items:center;padding:0;
  }
  .toggle:hover{color:var(--text)}

  /* ---- header / intro ---- */
  header{margin-top:5rem}
  .name{font-weight:700;font-size:1.05rem;line-height:1.4}
  .role{font-weight:700;font-size:1.05rem;line-height:1.4}
  .intro{margin-top:1.6rem;color:var(--dim)}
  .intro p{max-width:62ch}
  .intro p + p{margin-top:1.1rem}
  .intro em{font-style:italic;color:var(--text)}

  .socials{margin-top:1.8rem;display:flex;flex-wrap:wrap;gap:1.2rem}
  .socials a{
    color:var(--nav);text-decoration:none;font-size:0.9rem;
    border-bottom:1px solid var(--line);padding-bottom:1px;
    transition:color .15s ease,border-color .15s ease;
  }
  .socials a:hover,.socials a:focus-visible{color:var(--text);border-color:var(--text)}

  /* ---- section ---- */
  section{margin-top:4.5rem}
  .sec-head{
    display:flex;align-items:baseline;justify-content:space-between;
    margin-bottom:1.6rem;
  }
  .sec-head h2{font-weight:700;font-size:1rem}
  .sec-head a{
    font-weight:700;font-size:0.92rem;color:var(--text);text-decoration:none;
    border-bottom:1px solid transparent;transition:border-color .15s ease;
  }
  .sec-head a:hover,.sec-head a:focus-visible{border-color:var(--text)}

  .item{padding:1.4rem 0;border-top:1px solid var(--line)}
  .item:first-child{border-top:none;padding-top:0}
  .item h3{font-weight:700;font-size:1rem;line-height:1.35}
  .item .authors{margin-top:0.35rem;color:var(--dim);font-size:0.93rem;line-height:1.5}
  .item .authors .me{
    color:var(--text);
    text-decoration:underline;
    text-underline-offset:2px;
  }
  .item .venue{margin-top:0.25rem;font-style:italic;color:var(--dim);font-size:0.93rem;line-height:1.5}
  .item .links{margin-top:0.6rem;display:flex;gap:1.1rem}
  .item .links a{
    color:var(--nav);font-size:0.85rem;text-decoration:none;
    border-bottom:1px solid var(--line);padding-bottom:1px;
    transition:color .15s ease,border-color .15s ease;
  }
  .item .links a:hover{color:var(--text);border-color:var(--text)}

  footer{
    margin-top:5rem;padding:2rem 0;border-top:1px solid var(--line);
    color:var(--muted);font-size:0.85rem;
  }

  :focus-visible{outline:2px solid var(--text);outline-offset:3px;border-radius:2px}
</style>
</head>
<body>
  <div class="container">

    <nav>
      <!-- LOGO: swap the <svg> below for your own image:
