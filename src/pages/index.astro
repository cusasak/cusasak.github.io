      <a class="logo" href="/" aria-label="Home"><img src="/ll.svg" alt="Home"></a>
      <div class="nav-links">
        <a href="#publications">Publications</a>
		<a href="/cv.pdf" target="_blank" rel="noopener">CV</a>
        <button class="toggle" id="themeToggle" aria-label="Toggle theme">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" id="themeIcon">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </nav>

    <header>
      <!-- EDIT: name / role -->
      <div class="name">Chanryeol Lee</div>
      <div class="role">Graduate Student · KAIST</div>

      <div class="intro">
        <p>I am Chanryeol Lee, M.S. student at <a href="https://soc.kaist.ac.kr" target="_blank" rel="noopener">School of Computing</a>, <a href="https://kaist.ac.kr/" target="_blank" rel="noopener">KAIST</a>, and a member of <a href="https://vllab.kaist.ac.kr/index.php" target="_blank" rel="noopener">Vision and Learning Laboratory</a>, advised by <a href="https://maga33.github.io" target="_blank" rel="noopener">Prof. Seunghoon Hong</a>.</p>
        <p>My research explores how neural networks encode, adapt, and compress information in their weight space. I am particularly interested in parameter based approaches for efficient model adaptation and inference, with a current focus on encoding contextual information into weights for large language models.</p>

      </div>

	  <div class="socials">
        <a href="mailto:lcy9442@kaist.ac.kr">Email</a>
        <a href="https://github.com/cusasak/" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/cusasak/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://scholar.google.com/citations?user=_suZbMsAAAAJ" target="_blank" rel="noopener">Scholar</a>
      </div>
    </header>

    <section id="publications">
      <div class="sec-head">
        <h2>Publications</h2>
      </div>

	  <!-- Each entry: title / authors (wrap your name in <span class="me">) / venue in italic.
           The .links row is optional — delete it if you don't want links. -->

	  <div class="item">
        <h3>PatchKV: Weight Space Compensation of KV Cache</h3>
        <div class="authors"><span class="me">Chanryeol Lee</span>, Chanhyuk Lee, Yeonwoo Choi, Donggyun Kim<sup>†</sup>, Seunghoon Hong<sup>†</sup></div>
        <div class="venue">Under Review</div>
      </div>

      <div class="item">
        <h3>AdaRank: Adaptive Rank Pruning for Enhanced Model Merging</h3>
        <div class="authors">Chanhyuk Lee, Jiho Choi, <span class="me">Chanryeol Lee</span>, Donggyun Kim, Seunghoon Hong</div>
        <div class="venue">International Conference on Representation Learning (ICLR), 2026</div>
        <div class="links"><a href="https://arxiv.org/abs/2503.22178">arXiv</a><a href="https://github.com/david3684/AdaRank">code</a></div>
      </div>

    </section>

    <!-- ADD LATER: copy this block for Teaching / Awards / etc.
    <section id="teaching">
      <div class="sec-head">
        <h2>Teaching</h2>
      </div>
      <div class="item">
        <h3>Course name</h3>
        <div class="sub">Role · Term</div>
      </div>
    </section>
    -->

    <footer>© 2026 Chanryeol Lee</footer>

  </div>

<script>
  const root = document.documentElement;
  const btn = document.getElementById('themeToggle');
  const icon = document.getElementById('themeIcon');

  if (btn && icon) {
    const sun = '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>';
    const moon = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';

    btn.addEventListener('click', () => {
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      icon.innerHTML = next === 'dark' ? moon : sun;
    });
  }
  </script>
</body>
</html>
